# ════════════════════════════════════════════════════════════════════════════
# MELODIFY BOT - Environment Configuration
# Updated: April 5, 2026 - Optimized for Performance
# ════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED: DISCORD BOT CREDENTIALS ─────────────────────────────────────
# Discord Bot Token - Required to start the bot
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# ─── OPTIONAL: SPOTIFY API (Highly Recommended) ─────────────────────────────
# Spotify OAuth credentials for music platform integration
# Create an app here: https://developer.spotify.com/dashboard/
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── OPTIONAL: GENIUS API (For Lyrics) ────────────────────────────────────
# Genius API token for lyrics fetching
# Get it here: https://genius.com/api-clients
GENIUS_TOKEN=your_genius_token

# ─── PERFORMANCE OPTIMIZATION SETTINGS (Optional) ─────────────────────────
# Database Query Timeout (seconds)
# Default: 15s - Adjust based on your server performance
DB_QUERY_TIMEOUT=15

# Cache TTL Settings (seconds)
# URL metadata cache time-to-live (2 hours = 7200s)
CACHE_METADATA_TTL=7200
# Stream URL cache time-to-live (5 minutes = 300s)
CACHE_STREAM_TTL=300

# Process Pool Worker Count
# Default: Auto (based on CPU count) - Set 0 for auto, or specific number
PROCESS_POOL_WORKERS=0

# Queue Maximum Size
# Default: 5000 tracks - Prevent unbounded memory growth
QUEUE_MAX_SIZE=5000

# ─── LOGGING CONFIGURATION (Optional) ──────────────────────────────────────
# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log File (Set to empty string to disable file logging)
LOG_FILE=melodify.log
# Log Format: detailed or simple
LOG_FORMAT=detailed

# ─── 24/7 MODE SETTINGS (Optional) ────────────────────────────────────────
# Enable 24/7 mode (bot stays in voice even when idle)
ENABLE_247_MODE=false
# Silence loop check interval (seconds) - Lower = more responsive but higher CPU
SILENCE_CHECK_INTERVAL=15

# ─── VOICE & AUDIO SETTINGS (Optional) ────────────────────────────────────
# Voice timeout before auto-disconnect (seconds)
VOICE_TIMEOUT=300
# FFmpeg audio format optimization
AUDIO_FORMAT=bestaudio[acodec=opus]/bestaudio/best

# ─── ADVANCED: PLATFORM-SPECIFIC SETTINGS ─────────────────────────────────
# YouTube Cookies File (for age-restricted/bot-detection bypass)
YT_COOKIES_FILE=cookies_1.txt

# Playwright Browser (chromium, firefox, webkit)
PLAYWRIGHT_BROWSER=chromium

# ─── DEVELOPMENT/DEBUGGING (Optional) ──────────────────────────────────────
# Development Mode: Enable debug logging and reloads
DEV_MODE=false
# Profile Performance: Collect and log performance metrics
PROFILE_PERFORMANCE=false
